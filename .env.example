MONGODB_URI="mongodb+srv://USER:PASSWORD@HOST/rlp_digital?retryWrites=true&w=majority"
JWT_ACCESS_SECRET="replace-with-at-least-32-random-characters"
JWT_REFRESH_SECRET="replace-with-another-32-random-character-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"
# Public backend URL used for uploads, QR verify links, etc.
PUBLIC_BASE_URL="http://YOUR_PC_LAN_IP:3000"
# UPI Gateway callback needs a public backend URL. For local testing, set PUBLIC_BASE_URL
# to an ngrok/cloudflared URL like https://xxxx.ngrok-free.app.
UPI_GATEWAY_API_KEY=""
UPI_GATEWAY_ORDER_URL="https://api.upigateway.com/v1/order/create"
UPI_GATEWAY_CALLBACK_URL=""
UPI_GATEWAY_REDIRECT_URL=""
# Optional override; if omitted, backend uses ${PUBLIC_BASE_URL}/api/verify
VERIFY_BASE_URL=""
FRONTEND_URL="http://localhost:8081,http://YOUR_PC_LAN_IP:8081"
TRUST_PROXY=1
UPLOAD_DIR="./uploads"
UPLOAD_IMAGE_MAX_WIDTH=1600
UPLOAD_IMAGE_QUALITY=80
UPLOAD_THUMB_WIDTH=480
UPLOAD_THUMB_HEIGHT=480
UPLOAD_THUMB_QUALITY=72
UPLOAD_VIDEO_MAX_WIDTH=1280
UPLOAD_VIDEO_MAX_HEIGHT=720
UPLOAD_VIDEO_CRF=27
UPLOAD_VIDEO_PRESET="veryfast"
UPLOAD_VIDEO_AUDIO_BITRATE="96k"
POSTER_IMAGE_MAX_WIDTH=2200
POSTER_IMAGE_QUALITY=88
POSTER_THUMB_WIDTH=720
POSTER_THUMB_HEIGHT=960
POSTER_THUMB_QUALITY=82
